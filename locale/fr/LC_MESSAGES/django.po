msgid ""
"Phone number prefix not recognised. Select a country prefix from the list."
msgstr ""
"Préfixe de numéro de téléphone non reconnu. Veuillez sélectionner un "
"indicatif pays dans la liste."

#, fuzzy
#| msgid "Maximum sale rows accepted per API batch (1–100,000)."
msgid "Maximum sale rows accepted per API batch (1–100,000). 0 = no limit."
msgstr "Nombre maximum de lignes de vente acceptées par lot API (1–100 000)."

msgid ""
"Reject rows where submitted PPV deviates more than this % from the catalogue "
"PPV. Leave blank to disable."
msgstr ""
"Rejeter les lignes dont le PPV soumis s'écarte de plus de ce % du PPV "
"catalogue. Laisser vide pour désactiver."

#, fuzzy
#| msgid "Rejection rate % above which a yellow warning badge is shown (1–99)."
msgid ""
"Rejection rate % above which a yellow warning badge is shown (1–99). 0 = "
"disabled."
msgstr ""
"Taux de rejet % au-delà duquel un badge d’avertissement jaune s’affiche (1–"
"99).Taux de rejet % au-delà duquel un badge d’avertissement jaune s’affiche "
"(1–99)."

#, fuzzy
#| msgid ""
#| "Rejection rate % above which a red danger badge is shown (must exceed "
#| "warn threshold)."
msgid ""
"Rejection rate % above which a red danger badge is shown (must exceed warn "
"threshold). 0 = disabled."
msgstr ""
"Taux de rejet % au-delà duquel un badge danger rouge s'affiche (doit "
"dépasser le seuil d'avertissement)."

#, fuzzy
#| msgid "Maximum API requests per token per hour (1–10,000)."
msgid "Maximum API requests per token per hour (1–10,000). 0 = unlimited."
msgstr "Nombre maximum de requêtes API par jeton par heure (1–10 000)."

msgid "Must be between 1 and 100,000, or 0 for no limit."
msgstr "Doit être compris entre 1 et 100 000, ou 0 pour sans limite."

msgid "Must be between 0.01 and 100."
msgstr "Doit être compris entre 0,01 et 100."

msgid "Must be between 1 and 99, or 0 to disable."
msgstr "Doit être compris entre 1 et 99, ou 0 pour désactiver."

msgid "Must be between 1 and 100, or 0 to disable."
msgstr "Doit être compris entre 1 et 100, ou 0 pour désactiver."

msgid "Danger threshold must be strictly greater than the warn threshold."
msgstr ""
"Le seuil de danger doit être strictement supérieur au seuil d’avertissement."

msgid "Must be between 1 and 10,000, or 0 for no limit."
msgstr "Doit être compris entre 1 et 10 000, ou 0 pour illimité."

